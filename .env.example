COUNTIT_EMAIL=
COUNTIT_PASSWORD=
COUNTIT_COMPANY_NAME=

# Optional: usually leave these blank.
# Use them only when discount and stock need different CountIT companies.
COUNTIT_COMPANY_NAME_DISCOUNT=
COUNTIT_COMPANY_NAME_STOCK=

# Optional: usually leave blank. Defaults to the standard CountIT login URL.
COUNTIT_BASE_URL=

# Optional: set to 1 only when debugging CountIT company name detection/switching.
DEBUG_COUNTIT_COMPANY=

# Optional: only needed when reading private Google Sheets CSV exports.
GOOGLE_ACCESS_TOKEN=

# Do not commit .env or .env.local.
# Usually COUNTIT_EMAIL, COUNTIT_PASSWORD, and COUNTIT_COMPANY_NAME are enough.
